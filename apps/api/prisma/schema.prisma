generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  staffProfile  Staff?
  admissions    Admission[]   @relation("admittedBy")
  tasksCreated  Task[]        @relation("createdBy")
  notifications Notification[]

  @@map("users")
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
}

// ============================================
// PATIENT FLOW (Developer A)
// ============================================

model Patient {
  id               String        @id @default(uuid())
  mrn              String        @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           Gender
  contactPhone     String?
  emergencyContact String?
  status           PatientStatus @default(REGISTERED)
  departmentId     String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  department       Department    @relation(fields: [departmentId], references: [id])
  currentBed       Bed?          @relation("currentPatient")
  admissions       Admission[]
  tasks            Task[]
  transfersFrom    TransferRequest[] @relation("transferPatient")

  @@map("patients")
}

enum PatientStatus {
  REGISTERED
  ADMITTED
  TRANSFERRED
  DISCHARGED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Admission {
  id           String    @id @default(uuid())
  patientId    String
  departmentId String
  bedId        String?
  admittedById String
  admittedAt   DateTime  @default(now())
  dischargedAt DateTime?
  notes        String?

  // Relations
  patient    Patient    @relation(fields: [patientId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  bed        Bed?       @relation(fields: [bedId], references: [id])
  admittedBy User       @relation("admittedBy", fields: [admittedById], references: [id])

  @@map("admissions")
}

// ============================================
// BED MANAGEMENT (Developer B)
// ============================================

model Bed {
  id               String    @id @default(uuid())
  bedNumber        String
  ward             String
  departmentId     String
  status           BedStatus @default(AVAILABLE)
  bedType          BedType   @default(GENERAL)
  currentPatientId String?   @unique
  updatedAt        DateTime  @updatedAt

  // Relations
  department     Department  @relation(fields: [departmentId], references: [id])
  currentPatient Patient?    @relation("currentPatient", fields: [currentPatientId], references: [id])
  admissions     Admission[]

  @@unique([bedNumber, departmentId])
  @@map("beds")
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum BedType {
  GENERAL
  ICU
  PEDIATRIC
  MATERNITY
}

// ============================================
// TASK MANAGEMENT (Developer B)
// ============================================

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String?
  priority     Priority   @default(MEDIUM)
  status       TaskStatus @default(PENDING)
  departmentId String
  assignedToId String?
  patientId    String?
  createdById  String
  dueAt        DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  department Department @relation(fields: [departmentId], references: [id])
  assignedTo Staff?     @relation(fields: [assignedToId], references: [id])
  patient    Patient?   @relation(fields: [patientId], references: [id])
  createdBy  User       @relation("createdBy", fields: [createdById], references: [id])

  @@map("tasks")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ESCALATED
}

// ============================================
// STAFF SCHEDULING (Developer C)
// ============================================

model Staff {
  id             String    @id @default(uuid())
  userId         String    @unique
  employeeId     String    @unique
  firstName      String
  lastName       String
  role           StaffRole
  specialization String?
  departmentId   String
  isActive       Boolean   @default(true)

  // Relations
  user               User              @relation(fields: [userId], references: [id])
  department         Department        @relation(fields: [departmentId], references: [id])
  shifts             Shift[]
  tasks              Task[]
  transfersRequested TransferRequest[] @relation("requestedBy")
  transfersApproved  TransferRequest[] @relation("approvedBy")
  headOfDepartments  Department[]      @relation("headOfDept")

  @@map("staff")
}

enum StaffRole {
  DOCTOR
  NURSE
  TECHNICIAN
  ADMIN_STAFF
}

model Shift {
  id           String      @id @default(uuid())
  staffId      String
  departmentId String
  shiftType    ShiftType
  date         DateTime    @db.Date
  startTime    DateTime
  endTime      DateTime
  status       ShiftStatus @default(SCHEDULED)
  notes        String?

  // Relations
  staff      Staff      @relation(fields: [staffId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@map("shifts")
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

enum ShiftStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// DEPARTMENT COORDINATION (Developer C)
// ============================================

model Department {
  id           String  @id @default(uuid())
  name         String  @unique
  code         String  @unique
  floor        Int?
  building     String?
  capacity     Int
  headOfDeptId String?
  isActive     Boolean @default(true)

  // Relations
  headOfDept        Staff?            @relation("headOfDept", fields: [headOfDeptId], references: [id])
  beds              Bed[]
  staff             Staff[]
  patients          Patient[]
  admissions        Admission[]
  tasks             Task[]
  shifts            Shift[]
  transfersFrom     TransferRequest[] @relation("fromDept")
  transfersTo       TransferRequest[] @relation("toDept")

  @@map("departments")
}

model TransferRequest {
  id               String         @id @default(uuid())
  patientId        String
  fromDepartmentId String
  toDepartmentId   String
  requestedById    String
  approvedById     String?
  status           TransferStatus @default(PENDING)
  reason           String
  createdAt        DateTime       @default(now())
  resolvedAt       DateTime?

  // Relations
  patient        Patient    @relation("transferPatient", fields: [patientId], references: [id])
  fromDepartment Department @relation("fromDept", fields: [fromDepartmentId], references: [id])
  toDepartment   Department @relation("toDept", fields: [toDepartmentId], references: [id])
  requestedBy    Staff      @relation("requestedBy", fields: [requestedById], references: [id])
  approvedBy     Staff?     @relation("approvedBy", fields: [approvedById], references: [id])

  @@map("transfer_requests")
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// ============================================
// NOTIFICATIONS (Developer C)
// ============================================

model Notification {
  id            String           @id @default(uuid())
  recipientId   String
  type          NotificationType
  title         String
  message       String
  isRead        Boolean          @default(false)
  referenceType String?
  referenceId   String?
  createdAt     DateTime         @default(now())

  // Relations
  recipient User @relation(fields: [recipientId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  TASK_ASSIGNED
  TRANSFER_REQUEST
  SHIFT_CHANGE
  BED_UPDATE
  PATIENT_ADMITTED
  PATIENT_DISCHARGED
}
